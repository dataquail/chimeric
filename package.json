{
  "name": "@chimeric/source",
  "version": "0.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dataquail/chimeric.git"
  },
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "build:all": "nx run-many --target=build",
    "build:packages": "nx run-many --target=build --exclude=examples/** --exclude=@chimeric/website --exclude=@chimeric/e2e",
    "build:examples": "nx run-many --target=build --projects=examples/tanstack-query-spa",
    "test:all": "nx run-many --target=test",
    "test:packages": "nx run-many --target=test --exclude=examples/** --exclude=@chimeric/website",
    "test:examples": "nx run-many --target=test --projects=examples/tanstack-query-spa",
    "lint:all": "nx run-many --target=lint",
    "lint:packages": "nx run-many --target=lint --exclude=examples/** --exclude=@chimeric/website",
    "lint:examples": "nx run-many --target=lint --projects=examples/tanstack-query-spa",
    "watch:all": "pnpm run build:all && nx watch --all -- pnpm run build:all",
    "watch:packages": "pnpm run build:packages && nx watch --exclude=examples/** --exclude=@chimeric/website --exclude=@chimeric/e2e -- pnpm run build:packages",
    "watch:examples": "pnpm run build:examples && nx watch --projects=examples/tanstack-query-spa -- pnpm run build:examples",
    "dev:all": "pnpm run watch:all",
    "dev:examples": "pnpm run watch:examples",
    "typecheck:all": "nx run-many --target=typecheck",
    "precommit": "nx run-many -t lint test typecheck",
    "prettier": "prettier --ignore-unknown '**/*'",
    "prettier:write": "pnpm run prettier --write",
    "serve:tanstack-query-spa": "pnpm run build:examples && npx nx serve examples/tanstack-query-spa --base=/tanstack-query-spa",
    "dev:website": "pnpm --filter @chimeric/website dev",
    "build:website": "pnpm --filter @chimeric/website build",
    "preview:website": "pnpm --filter @chimeric/website preview",
    "troubleshoot:ci": "act -W .github/workflows/ci.yml workflow_dispatch",
    "prepare": "husky",
    "inject-token": "bash .devcontainer/inject-token.sh",
    "devpod:up": "pnpm run inject-token && bash -c 'devpod up . --id=\"$1\"' --",
    "devpod:delete": "bash -c 'devpod delete \"$1\"' --"
  },
  "private": true,
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint-react/eslint-plugin": "^2.13.0",
    "@eslint/js": "^9.23.0",
    "@next/eslint-plugin-next": "^16.2.4",
    "@nx/eslint": "22.6.5",
    "@nx/eslint-plugin": "22.6.5",
    "@nx/express": "22.6.5",
    "@nx/js": "22.6.5",
    "@nx/next": "22.6.5",
    "@nx/node": "22.6.5",
    "@nx/react": "22.6.5",
    "@nx/vite": "22.6.5",
    "@nx/vitest": "22.6.5",
    "@nx/web": "22.6.5",
    "@nx/webpack": "22.6.5",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.6.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@svgr/webpack": "^8.0.1",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "0.7.10",
    "@swc/core": "1.15.26",
    "@swc/helpers": "0.5.21",
    "@tanstack/react-query": "^5.100.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "25.6.0",
    "@types/react": "^19.0.12",
    "@types/react-dom": "19.0.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "4.1.4",
    "@vitest/spy": "4.1.4",
    "@vitest/ui": "4.1.4",
    "autoprefixer": "10.4.13",
    "eslint": "^9.23.0",
    "eslint-config-next": "16.2.3",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "husky": "^9.1.7",
    "jiti": "2.6.1",
    "jsdom": "~22.1.0",
    "jsonc-eslint-parser": "^2.4.0",
    "nx": "22.6.5",
    "postcss": "8.4.38",
    "prettier": "^3.8.3",
    "react-redux": "^9.0.0",
    "react-refresh": "^0.10.0",
    "tailwindcss": "3.4.3",
    "tslib": "^2.8.1",
    "typescript": "~5.7.3",
    "typescript-eslint": "8.58.1",
    "verdaccio": "6.5.1",
    "vite": "7.3.2",
    "vite-plugin-dts": "~4.5.3",
    "vitest": "4.1.4",
    "webpack-cli": "^5.1.4"
  },
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    }
  },
  "pnpm": {
    "overrides": {
      "axios": ">=1.15.0",
      "form-data": ">=4.0.4",
      "@jest/reporters>glob": ">=10.5.0",
      "@next/eslint-plugin-next>glob": ">=10.5.0",
      "jest-config>glob": ">=10.5.0",
      "jest-runtime>glob": ">=10.5.0",
      "rollup": ">=4.59.0",
      "jake>minimatch": ">=3.1.4",
      "@microsoft/api-extractor>minimatch": ">=3.1.4",
      "@eslint/config-array>minimatch": ">=3.1.4",
      "@eslint/eslintrc>minimatch": ">=3.1.4",
      "eslint>minimatch": ">=3.1.4",
      "test-exclude>minimatch": ">=3.1.4",
      "filelist>minimatch": ">=5.1.8",
      "@verdaccio/core>minimatch": ">=7.4.8",
      "@typescript-eslint/typescript-estree>minimatch": ">=9.0.7",
      "glob>minimatch": ">=9.0.7",
      "@swc/cli>minimatch": ">=9.0.7",
      "fork-ts-checker-webpack-plugin>minimatch": ">=3.1.4",
      "eslint-plugin-import>minimatch": ">=3.1.4",
      "eslint-plugin-react>minimatch": ">=3.1.4",
      "eslint-plugin-jsx-a11y>minimatch": ">=3.1.4",
      "@humanwhocodes/config-array>minimatch": ">=3.1.4",
      "@vue/language-core>minimatch": ">=9.0.7",
      "serialize-javascript": ">=7.0.3",
      "immutable": ">=5.1.5",
      "@svgr/plugin-svgo>svgo": ">=3.3.3",
      "flatted": ">=3.4.2",
      "micromatch>picomatch": ">=2.3.2",
      "anymatch>picomatch": ">=2.3.2",
      "tinyglobby>picomatch": ">=4.0.4",
      "vite>picomatch": ">=4.0.4",
      "@rollup/pluginutils>picomatch": ">=4.0.4",
      "vitest>picomatch": ">=4.0.4",
      "lodash": ">=4.18.0",
      "koa": ">=3.1.2",
      "node-forge": ">=1.4.0"
    }
  },
  "dependencies": {
    "axios": "^1.15.0",
    "express": "^4.21.2",
    "next": "16.1.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
