{
  "name": "@chimeric/source",
  "version": "0.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dataquail/chimeric.git"
  },
  "packageManager": "pnpm@10.7.0",
  "type": "module",
  "scripts": {
    "build:all": "nx run-many --target=build",
    "build:packages": "nx run-many --target=build --exclude=examples/**",
    "build:examples": "nx run-many --target=build --projects=examples/tanstack-query-spa",
    "test:all": "nx run-many --target=test",
    "test:packages": "nx run-many --target=test --exclude=examples/**",
    "test:examples": "nx run-many --target=test --projects=examples/tanstack-query-spa",
    "lint:all": "nx run-many --target=lint",
    "lint:packages": "nx run-many --target=lint --exclude=examples/**",
    "lint:examples": "nx run-many --target=lint --projects=examples/tanstack-query-spa",
    "watch:all": "pnpm run build:all && nx watch --all -- pnpm run build:all",
    "watch:packages": "pnpm run build:packages && nx watch --exclude=examples/** -- pnpm run build:packages",
    "watch:examples": "pnpm run build:examples && nx watch --projects=examples/tanstack-query-spa -- pnpm run build:examples",
    "dev:all": "pnpm run watch:all",
    "dev:examples": "pnpm run watch:examples",
    "typecheck:all": "nx run-many --target=typecheck",
    "precommit": "pnpm run lint:all && pnpm run test:all && pnpm run typecheck:all",
    "prettier": "prettier --ignore-unknown '**/*'",
    "prettier:write": "pnpm run prettier --write",
    "serve:tanstack-query-spa": "pnpm run build:examples && npx nx serve examples/tanstack-query-spa --base=/tanstack-query-spa",
    "dev:website": "pnpm --filter @chimeric/website dev",
    "build:website": "pnpm --filter @chimeric/website build",
    "preview:website": "pnpm --filter @chimeric/website preview",
    "troubleshoot:ci": "act -W .github/workflows/ci.yml workflow_dispatch",
    "prepare": "husky"
  },
  "private": true,
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint-react/eslint-plugin": "^1.19.0",
    "@eslint/js": "^9.23.0",
    "@next/eslint-plugin-next": "^16.0.1",
    "@reduxjs/toolkit": "^2.6.0",
    "@nx/eslint": "22.6.4",
    "@nx/eslint-plugin": "22.6.4",
    "@nx/express": "^22.6.4",
    "@nx/js": "22.6.4",
    "@nx/next": "^22.6.4",
    "@nx/node": "22.6.4",
    "@nx/react": "22.6.4",
    "@nx/vite": "22.6.4",
    "@nx/web": "22.6.4",
    "@nx/webpack": "22.6.4",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.7",
    "@svgr/webpack": "^8.0.1",
    "@swc-node/register": "~1.9.2",
    "@swc/cli": "0.6.0",
    "@swc/core": "~1.5.29",
    "@swc/helpers": "~0.5.15",
    "@tanstack/react-query": "^5.96.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "20.19.9",
    "@types/react": "^19.0.12",
    "@types/react-dom": "19.0.0",
    "@types/uuid": "^9.0.8",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.0.9",
    "@vitest/ui": "^3.0.9",
    "autoprefixer": "10.4.13",
    "eslint": "^9.23.0",
    "eslint-config-next": "^16.0.1",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "husky": "^9.1.7",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "jsonc-eslint-parser": "^2.4.0",
    "nx": "22.6.4",
    "postcss": "8.4.38",
    "prettier": "^2.8.8",
    "react-redux": "^9.0.0",
    "react-refresh": "^0.10.0",
    "tailwindcss": "3.4.3",
    "tslib": "^2.8.1",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.28.0",
    "verdaccio": "^6.1.0",
    "vite": "^6.2.3",
    "vite-plugin-dts": "~4.5.3",
    "vitest": "^3.0.9",
    "webpack-cli": "^5.1.4"
  },
  "nx": {
    "includedScripts": [],
    "targets": {
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "express": "^4.21.2",
    "next": "~16.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
