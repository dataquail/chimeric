{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM"],
    "types": ["vite/client"],
    "paths": {
      "src/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.svelte", "vite.config.mts"],
  "exclude": ["node_modules", "dist"],
  "references": [
    {
      "path": "../../packages/svelte-query/tsconfig.lib.json"
    },
    {
      "path": "../../packages/svelte/tsconfig.lib.json"
    }
  ]
}
