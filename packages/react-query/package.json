{
  "name": "@chimeric/react-query",
  "version": "1.1.0",
  "description": "React Query utilities for chimeric interfaces",
  "author": "zacharyweidenbach",
  "license": "MIT",
  "keywords": [
    "react",
    "react-query",
    "tanstack-query",
    "typescript",
    "caching",
    "mutation",
    "interface",
    "ioc",
    "di",
    "dependency injection"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dataquail/chimeric.git",
    "directory": "packages/react-query"
  },
  "homepage": "https://dataquail.github.io/chimeric",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "typings": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "react-server": {
        "types": "./dist/index.d.ts",
        "import": "./dist/server.esm.js",
        "require": "./dist/server.cjs.js"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "default": "./dist/index.esm.js"
    }
  },
  "dependencies": {
    "@chimeric/core": "workspace:*"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@chimeric/react": "workspace:*",
    "@tanstack/react-query": "^5.96.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  }
}
