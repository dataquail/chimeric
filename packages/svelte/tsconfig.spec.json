{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/vitest",
    "types": ["vitest/globals", "vitest/importMeta", "vite/client", "node", "vitest", "svelte"],
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "Bundler"
  },
  "include": [
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "src/**/*.test.js",
    "src/**/*.spec.js",
    "src/**/*.test.jsx",
    "src/**/*.spec.jsx",
    "src/**/*.d.ts",
    "src/**/__tests__/**/*.tsx",
    "src/**/__tests__/**/*.ts",
    "src/**/*.svelte.ts",
    "src/**/*.spec.svelte.ts",
    "src/**/*.svelte"
  ],
  "references": [
    {
      "path": "./tsconfig.lib.json"
    }
  ]
}
