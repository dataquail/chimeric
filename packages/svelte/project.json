{
  "name": "@chimeric/svelte",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/svelte/src",
  "projectType": "library",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": ["^typecheck"],
      "options": {
        "command": "tsc --build --emitDeclarationOnly tsconfig.lib.json",
        "cwd": "packages/svelte"
      }
    },
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "packages/svelte/dist"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    }
  },
  "tags": []
}
